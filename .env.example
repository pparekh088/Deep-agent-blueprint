# ── Template core config (every domain sets these) ─────────────────────────
SERVICE_NAME=domain-deep-agent
DOMAIN=jira                      # selects the adapter: jira | websearch | <your-domain>
ENV=dev

# Service API keys (Layer 1 auth). JSON: {"<consumer-id>": "<secret>", ...}
# Multiple keys active at once = zero-downtime rotation.
API_KEYS={"chat-orchestrator": "dev-only-key-change-me"}

REDIS_URL=redis://localhost:6379/0

# TTLs / job semantics (seconds)
RESULT_TTL_S=7200
PROPOSAL_TTL_S=1800
JOB_TIMEOUT_S=600
JOB_MAX_ATTEMPTS=2

# Azure OpenAI — Entra ID (AAD) auth, no API key. DefaultAzureCredential is
# used, so locally `az login` is enough; on AKS use workload identity.
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21

# PAT envelope encryption (USER_PAT domains only).
# Production: full Key Vault key identifier URL. Leave empty for local dev and
# set LOCAL_CRYPTO_KEY_B64 instead (base64 of 32 random bytes; NEVER in prod).
AZURE_KEYVAULT_KEY_ID=
LOCAL_CRYPTO_KEY_B64=

# Salt for the principal hash used in poll authorization (any random string).
PRINCIPAL_HASH_SALT=change-me

# ── DOMAIN-SPECIFIC config (only the active domain's block is needed) ──────
JIRA_BASE_URL=https://jira.example.com
WEBSEARCH_API_KEY=
WEBSEARCH_BASE_URL=https://api.tavily.com
